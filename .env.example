# Database
POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk_user
POSTGRES_PASSWORD=helpdesk_pass_123
DATABASE_URL=postgresql://helpdesk_user:helpdesk_pass_123@db:5432/helpdesk

# Django
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=helpdesk-backend

# Anomaly Injection (set to true to enable)
INJECT_DELAY=false
INJECT_SLOW_QUERY=false
INJECT_ERRORS=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_INTERNAL_API_URL=http://backend:8000
