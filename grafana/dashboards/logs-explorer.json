{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "All request logs (every request is logged)",
      "type": "logs",
      "description": "Shows all logs from the backend. If this has data, logs are flowing; other panels filter to errors only.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${logs_datasource}" },
      "targets": [
        {
          "expr": "{job=\"helpdesk-backend\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "wrapLogMessage": true
      }
    },
    {
      "title": "Error Logs by Severity",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "${logs_datasource}" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({job=\"helpdesk-backend\"} | json | level =~ \"ERROR|WARNING|CRITICAL\" [5m]))",
          "legendFormat": "{{ level }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Login Failure Events",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "${logs_datasource}" },
      "targets": [
        {
          "expr": "{job=\"helpdesk-backend\"} |= \"login_failed\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "wrapLogMessage": true
      }
    },
    {
      "title": "All Error Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "${logs_datasource}" },
      "targets": [
        {
          "expr": "{job=\"helpdesk-backend\"} | json | level = \"ERROR\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "wrapLogMessage": true
      }
    },
    {
      "title": "Logs by Trace ID",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "${logs_datasource}" },
      "targets": [
        {
          "expr": "{job=\"helpdesk-backend\"} |= \"$trace_id\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "wrapLogMessage": true
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["helpdesk", "logs"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Logs datasource",
        "multi": false,
        "name": "logs_datasource",
        "options": [],
        "query": "loki",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "description": "Filter logs by trace ID",
        "hide": 0,
        "label": "Trace ID",
        "name": "trace_id",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Logs Explorer",
  "uid": "logs-explorer"
}
